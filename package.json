{
  "name": "nexusroute",
  "version": "2.1.6",
  "description": "The Intelligent AI Nexus — one gateway, every AI provider, $0 to start.",
  "license": "MIT",
  "bin": {
    "nexusgate": "dist/cli.js"
  },
  "files": [
    "dist/",
    ".next/standalone/",
    "nexus-api/dist/"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "next dev -p 4200",
    "build": "next build",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "api:dev": "cd nexus-api && bun run dev",
    "build:api": "cd nexus-api && npx nest build",
    "build:web": "next build",
    "build:cli": "esbuild cli/index.ts --bundle --minify --platform=node --format=cjs --outfile=dist/cli.js",
    "build:all": "npm run build:api && npx javascript-obfuscator nexus-api/dist --output nexus-api/dist --compact true --string-array true --string-array-encoding base64 && npm run build:web && node scripts/clean-standalone.js && npm run build:cli",
    "build:bin": "bun scripts/build-binaries.ts",
    "prepublishOnly": "npm run build:all"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
